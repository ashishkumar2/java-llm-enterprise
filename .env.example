# === OpenAI Configuration ===
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_ORG_ID=

# === Azure OpenAI Configuration (Optional) ===
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_ID=

# === Database Configuration ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=llm_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_SSL_MODE=disable

JDBC_URL=jdbc:postgresql://${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DATABASE}
POSTGRES_URL=jdbc:postgresql://localhost:5432/llm_db
JDBC_DRIVER=org.postgresql.Driver

# === Redis Configuration ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL=false
REDIS_DATABASE=0

# === Kafka Configuration ===
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# === Application Configuration ===
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/
SPRING_PROFILES_ACTIVE=local

# === Logging Configuration ===
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_ENTERPRISE=DEBUG
LOGGING_PATTERN_CONSOLE=%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n

# === OpenTelemetry Configuration ===
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
OTEL_SERVICE_NAME=java-llm-enterprise
OTEL_SDK_DISABLED=false

# === Prometheus Configuration ===
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,metrics,prometheus
MANAGEMENT_ENDPOINT_HEALTH_PROBES_ENABLED=true

# === Security Configuration ===
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION_HOURS=24

# === AWS Configuration ===
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# === S3 Configuration ===
AWS_S3_BUCKET=
AWS_S3_REGION=

# === Secrets Manager ===
AWS_SECRETS_MANAGER_ENABLED=false
SECRETS_MANAGER_REGION=us-east-1

# === Email Configuration ===
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USER=
MAIL_SMTP_PASSWORD=
MAIL_FROM=noreply@example.com

# === Feature Flags ===
FEATURE_RAG_ENABLED=true
FEATURE_AGENTS_ENABLED=false
FEATURE_MULTI_LLM_ROUTING_ENABLED=false

# === Rate Limiting ===
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# === Observability ===
TRACE_SAMPLING_RATE=1.0
METRICS_ENABLED=true
AUDIT_LOGGING_ENABLED=true

# === Vector Store Configuration ===
VECTOR_STORE_TYPE=pgvector
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# === Document Processing ===
MAX_UPLOAD_SIZE_MB=50
SUPPORTED_FORMATS=pdf,docx,txt,md

# === Cache Configuration ===
CACHE_TTL_MINUTES=60
CACHE_MAX_SIZE=10000

# === Async Configuration ===
ASYNC_CORE_POOL_SIZE=5
ASYNC_MAX_POOL_SIZE=10
ASYNC_QUEUE_CAPACITY=100

# === Development Only ===
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_SHOW_SQL=false
